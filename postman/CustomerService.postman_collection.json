          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 204\", () => pm.response.to.have.status(204));",
                  "pm.environment.set(\"refreshToken\", \"\");",
                  "pm.environment.set(\"accessToken\", \"\");"
                ]
              }
            }
          ]
        }
      ]
