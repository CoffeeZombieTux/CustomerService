      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phone\": \"+49123456789\",\n  \"agreements\": [\n    { \"type\": \"TERMS_OF_SERVICE\", \"version\": 1, \"accepted\": true },\n    { \"type\": \"PRIVACY_POLICY\", \"version\": 1, \"accepted\": true },\n    { \"type\": \"LOYALTY_PROGRAM_TERMS\", \"version\": 1, \"accepted\": true },\n    { \"type\": \"MARKETING_EMAIL\", \"version\": 1, \"accepted\": false }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201\", () => pm.response.to.have.status(201));",
                  "pm.test(\"Response has message\", () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"message\");",
                  "    pm.expect(body.message).to.be.a(\"string\").and.not.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Resend Activation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"{{testEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/resend-activation",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "resend-activation"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Response has message\", () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"message\");",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Activate Account - Step 1 (Validate Token)",
          "protocolProfileBehavior": { "followRedirects": false },
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/activate?token=<paste-token-from-logs>",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "activate"],
              "query": [{ "key": "token", "value": "<paste-token-from-logs>" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Step 1 of two-step activation.",
                  "// Validates the token without consuming it — no side effects.",
                  "// Copy the token UUID from the app logs (NoOpEmailService prints it).",
                  "// 200 — token valid; 401 — token invalid or expired.",
                  "pm.test(\"Token is valid\", () => {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Activate Account - Step 2 (Confirm)",
          "protocolProfileBehavior": { "followRedirects": false },
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<paste-token-from-logs>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/activate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "activate"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Step 2 of two-step activation.",
                  "// Consumes the token and enables the account.",
                  "// Returns 302 → ACTIVATION_SUCCESS_URL on success.",
                  "pm.test(\"Activation successful\", () => {",
                  "    pm.expect(pm.response.code).to.equal(302);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));",
                  "pm.test(\"Response has tokens\", () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property(\"accessToken\");",
                  "    pm.expect(body).to.have.property(\"refreshToken\");",
                  "    pm.expect(body.accessToken).to.be.a(\"string\").and.not.empty;",
                  "    pm.expect(body.refreshToken).to.be.a(\"string\").and.not.empty;",
                  "    pm.environment.set(\"accessToken\", body.accessToken);",
                  "    pm.environment.set(\"refreshToken\", body.refreshToken);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"token\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "refresh"]
