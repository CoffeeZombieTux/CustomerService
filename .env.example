# JWT signing key — 256-bit, base64. Generate your own:
#   openssl rand -base64 32
JWT_SECRET=replace-me-with-base64-256-bit-key

DB_URL=jdbc:postgresql://localhost:5432/customerdb
DB_USERNAME=postgres
DB_PASSWORD=postgres

ACTIVATION_BUTTON_URL=http://localhost:4200/activate
ACTIVATION_SUCCESS_URL=http://localhost:4200/activation-success
ACTIVATION_FAIL_URL=http://localhost:4200/activation-failed

# Internal service-to-service key. Generate your own:
#   openssl rand -hex 32
INTERNAL_API_KEY=replace-me-with-random-hex

REFRESH_TOKEN_CLEANUP_BATCH_SIZE=1000